{
  "name": "@bconnorwhite/eslint-config",
  "version": "1.0.0",
  "description": "Shared ESLint configuration",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "Connor White",
    "email": "oss@bconnorwhite.com",
    "url": "https://bconnorwhite.com"
  },
  "homepage": "https://github.bconnorwhite.com/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bconnorwhite/eslint-config.git"
  },
  "bugs": "https://github.com/bconnorwhite/eslint-config/issues",
  "keywords": [
    "eslint",
    "config",
    "lint",
    "typescript",
    "react"
  ],
  "main": "./build/index.js",
  "exports": {
    ".": "./build/index.js",
    "./node": "./build/node.js",
    "./react": "./build/react.js"
  },
  "files": [
    "build/**/!(tsconfig.tsbuildinfo)"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project ./tsconfig.json --incremental",
    "lint": "npm run build && ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts --config ./build/node.js",
    "prepack": "npm run build",
    "test": "node --test",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@bconnorwhite/tsconfig": "^1.0.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.9.3"
  },
  "eslintConfig": {
    "extends": "./build/node.js"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-n": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    }
  }
}
